// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AssetCode {
  code      String    @id @unique
  name      String
  unit      String?
  toUSD     Decimal?  @db.Decimal(18, 8)
  toEUR     Decimal?  @db.Decimal(18, 8)
  toIDR     Decimal?  @db.Decimal(18, 8)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  investments Investment[]

  @@map("asset_codes")
}

model Investment {
  id               String    @id @default(uuid())
  code             String
  userId           String
  walletId         String?
  quantity         Decimal   @db.Decimal(18, 8)
  initialValuation Decimal   @db.Decimal(18, 8)
  amount           Decimal   @db.Decimal(18, 8)
  date             DateTime
  description      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  assetCode      AssetCode        @relation(fields: [code], references: [code])
  investmentSold InvestmentSold[]

  @@index([code])
  @@map("investments")
}

model InvestmentSold {
  id           String    @id @default(uuid())
  investmentId String
  userId       String
  walletId     String?
  quantity     Decimal?  @db.Decimal(18, 8)
  sellPrice    Decimal?  @db.Decimal(18, 8)
  amount       Decimal   @db.Decimal(18, 8)
  date         DateTime
  description  String?
  deficit      Decimal?  @db.Decimal(18, 8)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  investment Investment @relation(fields: [investmentId], references: [id])

  @@index([investmentId])
  @@map("investments_sold")
}
